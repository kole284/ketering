# Required database connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/keteringgo

# Public app URL used by documentation and future clients
APP_URL=http://localhost:3000

# Comma-separated CORS origins for API clients.
# Use http://localhost:3000 for local web, add Android/staging origins as needed.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Optional LAN origins for `next dev`, comma-separated.
NEXT_ALLOWED_DEV_ORIGINS=

# Optional notification recipient for new order SMS notifications.
# Example format: +381641234567
ORDER_NOTIFICATION_PHONE=

# Optional rate/body limits for order creation
ORDER_RATE_LIMIT_WINDOW_MS=60000
ORDER_RATE_LIMIT_MAX=20
ORDER_REQUEST_MAX_BYTES=16384
DEFAULT_ORDER_LEAD_TIME_MINUTES=60

# Optional Resend email provider
RESEND_API_KEY=
EMAIL_FROM=

# Optional EmailJS email provider fallback
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=

# Optional Twilio SMS provider
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
